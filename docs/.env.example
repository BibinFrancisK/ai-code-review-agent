# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit secrets.

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Google Gemini (https://aistudio.google.com)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_GEMINI_MODEL=gemini-2.0-flash

# PostgreSQL — used by the db service in docker-compose.yml
CODE_REVIEWER_POSTGRES_DB=codereviewer
CODE_REVIEWER_POSTGRES_USER=your_db_user_here
CODE_REVIEWER_POSTGRES_PASSWORD=your_db_pw_here
CODE_REVIEWER_POSTGRES_PORT=5432

# Spring datasource — hostname is "db" (Docker Compose service name)
# Change to localhost if running the app outside Docker (mvn spring-boot:run)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/codereviewer
SPRING_DATASOURCE_USERNAME=your_db_user_here
SPRING_DATASOURCE_PASSWORD=your_db_pw_here
